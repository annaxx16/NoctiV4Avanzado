# Nocti — configuración única para brain (Python) y exec (Node).
# Copiar a `.env` y rellenar. `.env` está gitignoreado.
#
#   cp .env.example .env
#
# Con `docker compose up`, DATABASE_URL y REDIS_URL se sobreescriben con los
# nombres de servicio de la red de compose. Los valores de abajo son para dev local.

# ==========================================================================
# INFRA — compartida por brain y exec
# ==========================================================================

# Producción. Aquí vive el histórico de book_snapshots que alimenta el go/no-go.
DATABASE_URL=postgresql+psycopg://umbra:umbra_dev@localhost:5432/umbra
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO

# Base de los tests. Los tests ESCRIBEN Y BORRAN filas, así que jamás puede ser
# la de arriba: tests/conftest.py rechaza cualquier nombre que no contenga 'test'.
# Sin esta variable, los tests de integración fallan a propósito contra una base
# inexistente, en vez de escribir en producción sin decir nada.
#   docker compose --profile db up -d      # levanta umbra_test en el 5434
UMBRA_TEST_DATABASE_URL=postgresql+psycopg://umbra:umbra_dev@localhost:5434/umbra_test

# ==========================================================================
# BRAIN (apps/brain) — el que decide QUÉ y CUÁNTO
# ==========================================================================

# sim | paper | shadow | live.  `live` no tiene code path todavía: no firma nada.
#
# `shadow` (Fase 3): el paper trading sigue exactamente igual y, además, cada señal
# aceptada emite un intent a `nocti:intents` para que exec lo cotice contra el libro
# real. Nadie firma. El resultado se lee con `python scripts/shadow_report.py`.
MODE=sim

# Bus de intents. Solo se usan cuando MODE=shadow.
#
# La tolerancia que brain declara: exec camina el libro hasta ese coste y rechaza más
# allá. NO es lo que el modelo predice que costará — son dos cosas. Un rechazo por
# exceso conserva la medición, así que subir esto no «arregla» nada: solo mueve dónde
# cae la compuerta.
INTENT_MAX_SLIPPAGE_BPS=500
# Cuánto vive un intent. El poller tickea cada 30s; a los 60s el libro es otro.
INTENT_TTL_SEC=60
INTENT_PUBLISH_BATCH=100

# Requerido para /admin/* (halt, resume, flatten). Si queda vacío, esos
# endpoints se rechazan (fail-closed) y el botón de halt del dashboard NO funciona.
# Generar con:  python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=

# --- Riesgo y sizing ---
# OJO: los defaults de src/umbra/config.py son más conservadores que estos.
# MIN_EDGE=0.003 sobre un P_fair sin calibrar (passthrough de la EMA) es,
# en la práctica, operar sobre ruido. Ver MERGE_PLAN.md §6.
BANKROLL_USD=1000
KELLY_KAPPA=0.15
MIN_EDGE=0.02
MAX_RISK_PER_TRADE_USD=50
MAX_EXPOSURE_PER_MARKET_USD=200
MAX_GROSS_EXPOSURE_PCT=0.50
MIN_SIGNAL_CONFIDENCE=0.10
MAX_TIME_TO_RESOLUTION_HOURS_FLOOR=2

# --- Edges ---
OVERREACTION_SIGMA_THRESHOLD=3.0
ENABLE_MOMENTUM_EDGE=true
MOMENTUM_MIN_DELTA=0.003
MOMENTUM_LOOKBACK_SNAPSHOTS=6

# --- Universo y loops ---
UNIVERSE_TOP_N=20
POLL_INTERVAL_SEC=30
TA_HARD_REJECT_ENABLED=false

# Si Redis cae, ¿asumir halt? En live SIEMPRE se asume halt (fail-closed,
# hardcodeado). Este flag solo relaja el comportamiento en sim.
REDIS_FAIL_CLOSED_IN_SIM=false

# ==========================================================================
# EXEC (apps/exec) — el que decide CÓMO llenar, y el único que firma
# ==========================================================================

# Clave privada de la wallet de Polygon. 66 caracteres (0x + 64 hex).
# Con DRY_RUN=true se usa una dummy key y NO se firma nada.
# NUNCA commitear esto. NUNCA compartirlo.
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Interruptor maestro de exec. `true` = no se firma ninguna orden.
DRY_RUN=true

CAPITAL_USD=250

# --- Riesgo de exec (las 4 capas de canTrade()) ---
DAILY_MAX_LOSS_PCT=0.05
MONTHLY_MAX_LOSS_PCT=0.15
MAX_DRAWDOWN_PCT=0.25
TOTAL_MAX_LOSS_PCT=0.40

# --- Estrategias de exec ---
SMART_MONEY_ENABLED=true
ARBITRAGE_ENABLED=true
DIP_ARB_ENABLED=true
DIRECT_TRADING_ENABLED=false

# --- Dashboard React de exec ---
DASHBOARD_PORT=3001

# ==========================================================================
# BUS — el contrato entre brain y exec (ver packages/contracts)
# ==========================================================================

# Fase 1: exec publica el book en tiempo real a `book:{condition_id}`.
# Con false, brain sigue con su poller REST de 30s.
NOCTI_BOOK_PUBLISHER_ENABLED=false

# Fase 3: exec consume `nocti:intents`. shadow = cotiza pero NO firma.
NOCTI_EXEC_MODE=off
# off | shadow | live
